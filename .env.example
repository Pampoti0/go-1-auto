# Google PageSpeed Insights API key (console.cloud.google.com → Credentials)
PSI_API_KEY=your-psi-api-key

# Google Sheet nhận kết quả (share Editor cho service account)
SHEET_ID=your-sheet-id

# Service account: chọn MỘT trong hai cách
# Cách 1 — đường dẫn file (chạy local):
SERVICE_ACCOUNT_FILE=service_account.json
# Cách 2 — dán nguyên nội dung JSON (deploy AgentBase, 1 dòng):
# SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Tùy chọn — MaaS LLM để chat hiểu câu tự nhiên (không có vẫn chạy: fallback keyword)
# MAAS_BASE_URL=https://...../v1
# MAAS_API_KEY=your-maas-key
# MAAS_MODEL=Qwen-3-27B

# Tùy chọn — bỏ trống dùng mặc định
# URLS=https://example.com,https://example.com/about
# STRATEGIES=mobile,desktop
# SCHEDULE_MODE=monthly
# SCHEDULE_TIME=08:00
# SCHEDULE_DAY_OF_MONTH=4
# REQUEST_DELAY=2
# RUN_SCHEDULER=true
# PORT=8000
