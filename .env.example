# Google PageSpeed Insights API key (console.cloud.google.com → Credentials)
PSI_API_KEY=your-psi-api-key

# Google Sheet nhận kết quả (share Editor cho service account)
SHEET_ID=your-sheet-id

# Service account: chọn MỘT trong hai cách
# Cách 1 — đường dẫn file (chạy local):
SERVICE_ACCOUNT_FILE=service_account.json
# Cách 2 — dán nguyên nội dung JSON (deploy AgentBase, 1 dòng):
# SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Tùy chọn — MaaS LLM để chat hiểu câu tự nhiên (không có vẫn chạy: fallback keyword)
# MAAS_BASE_URL=https://...../v1
# MAAS_API_KEY=your-maas-key
# MAAS_MODEL=Qwen-3-27B

# SEO Agent — OAuth user token: dán nội dung token.json (deploy) hoặc để file token.json (local)
# SEO_TOKEN_JSON={"token":...}
SEO_SITE_URL=https://your-site.com/
GA4_PROPERTY_ID=your-ga4-property-id
SEO_SHEET_ID=your-seo-sheet-id
# SEO_TRACKED_URLS=/path-1/,/path-2/
# SEO_RUN_DAY_OF_MONTH=8
# SEO_RUN_TIME=08:00

# Tùy chọn — bỏ trống dùng mặc định
# URLS=https://example.com,https://example.com/about
# STRATEGIES=mobile,desktop
# SCHEDULE_MODE=monthly
# SCHEDULE_TIME=08:00
# SCHEDULE_DAY_OF_MONTH=4
# REQUEST_DELAY=2
# RUN_SCHEDULER=true
# PORT=8000

# Paid Campaigns (Google Ads, read-only monitor)
# GOOGLE_ADS_DEVELOPER_TOKEN=your-dev-token
# GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
# GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
# GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-mcc-id
# GOOGLE_ADS_CUSTOMER_ID=your-customer-id

# AgentBase Memory (trí nhớ hội thoại + fact dài hạn)
# Tạo store: bash .claude/skills/agentbase/scripts/memory.sh create ... (xem README)
# Trên AgentBase Runtime: GREENNODE_CLIENT_ID/SECRET được tự inject, chỉ cần MEMORY_ID.
# MEMORY_ID=mem_xxxxxxxx
# MEMORY_STRATEGY_ID=  # tùy chọn — tự dò strategy đầu tiên nếu bỏ trống

# Web Search (DeCho tìm thông tin ngoài — tùy chọn)
# Có key Tavily thì kết quả tốt hơn; không có thì tự fallback DuckDuckGo (hạn chế).
# Trên AgentBase nhớ allowlist domain api.tavily.com / api.duckduckgo.com
# TAVILY_API_KEY=tvly-xxxxxxxx


# Đọc ảnh (vision) — tùy chọn: model hỗ trợ ảnh trên MaaS
# Nếu để trống sẽ dùng model đang chọn; chỉ chạy được nếu model đó nhận ảnh.
# MAAS_VISION_MODEL=google/gemma-4-31b-it
